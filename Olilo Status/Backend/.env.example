# ---------------------------------------------------------------------------
# Olilo Status notifications backend - configuration
# Copy to `.env` and fill in. Never commit the real `.env`.
# ---------------------------------------------------------------------------

# HTTP server
PORT=3000
# Shared secret required on every /api request via the `x-api-key` header.
# Leave blank to disable auth (not recommended outside local dev).
API_KEY=

# PostgreSQL connection string
DATABASE_URL=postgres://olilo:olilo@localhost:5432/olilo_status
# Set to "require" to force TLS to the database (e.g. managed Postgres).
DATABASE_SSL=
# Host port the bundled docker-compose Postgres publishes. Change this (and the
# port in DATABASE_URL for local runs) if 5432 is already taken on your machine.
DB_PORT=5432

# ---------------------------------------------------------------------------
# Upstream status page (Instatus-style API)
# ---------------------------------------------------------------------------
STATUS_BASE_URL=https://status.olilo.co.uk
# How often to poll the status page, in seconds.
POLL_INTERVAL_SECONDS=60

# ---------------------------------------------------------------------------
# Reverse proxy (only used by the optional `proxy` compose profile)
# ---------------------------------------------------------------------------
# Public hostname the nginx proxy serves (and the cert is issued for).
PROXY_DOMAIN=notifications.example.com

# ---------------------------------------------------------------------------
# Apple Push Notification service (APNs) - token-based auth (.p8 key)
# Create the key at https://developer.apple.com/account -> Keys.
# ---------------------------------------------------------------------------
APNS_ENABLED=true
# Either point at a .p8 file...
APNS_KEY_PATH=./secrets/AuthKey.p8
# ...or paste the PEM contents directly (takes precedence if set).
APNS_KEY=
APNS_KEY_ID=ABCDE12345
APNS_TEAM_ID=ABCDE12345
# The app's bundle identifier (APNs topic).
APNS_BUNDLE_ID=uk.co.olilo.status
# Use the sandbox host for development builds, production for App Store / TestFlight.
APNS_PRODUCTION=false

# ---------------------------------------------------------------------------
# Firebase Cloud Messaging (FCM) - Android
# Download a service account JSON from Firebase Console -> Project settings ->
# Service accounts -> Generate new private key.
# ---------------------------------------------------------------------------
FCM_ENABLED=true
# Either point at the service account file...
FCM_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# ...or paste the JSON contents directly (takes precedence if set).
FCM_SERVICE_ACCOUNT=